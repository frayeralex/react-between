{
    "name": "react-interpose",
    "version": "0.1.0",
    "description": "Insert dividers between React children that handles conditionally rendered components",
    "author": "Oleksii Boiko <frayeralex>",
    "license": "MIT",
    "type": "module",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/frayeralex/react-interpose.git"
    },
    "homepage": "https://github.com/frayeralex/react-interpose#readme",
    "bugs": {
        "url": "https://github.com/frayeralex/react-interpose/issues"
    },
    "keywords": [
        "react",
        "interpose",
        "separator",
        "divider",
        "intersperse",
        "children",
        "conditional-render",
        "typescript"
    ],
    "main": "dist/index.cjs",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "rollup -c",
        "dev": "rollup -c -w",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "playground": "yarn --cwd examples/basic dev",
        "prepublishOnly": "yarn build",
        "preversion": "yarn typecheck && yarn test && yarn build",
        "release:patch": "npm version patch -m \"chore: release v%s\" && git push --follow-tags",
        "release:minor": "npm version minor -m \"chore: release v%s\" && git push --follow-tags",
        "release:major": "npm version major -m \"chore: release v%s\" && git push --follow-tags"
    },
    "peerDependencies": {
        "react": ">=16.8.0",
        "react-dom": ">=16.8.0"
    },
    "devDependencies": {
        "@rollup/plugin-node-resolve": "^16.0.3",
        "@rollup/plugin-typescript": "^12.3.0",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "jsdom": "^29.0.2",
        "prettier": "^3.8.2",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "rollup": "^4.60.1",
        "rollup-plugin-dts": "^6.4.1",
        "tslib": "^2.8.1",
        "typescript": "^6.0.2",
        "vitest": "^4.1.4"
    }
}
